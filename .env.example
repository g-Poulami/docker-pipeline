# .env.example
# Copy this file to .env and fill in your paths.
# The .env file is loaded automatically by Docker Compose.
# Never commit .env to git — it contains your local paths.

# Directory containing FASTQ files
READS_DIR=/path/to/your/fastq/directory

# Filenames of paired-end reads inside READS_DIR
R1=SRR062634_R1.fastq.gz
R2=SRR062634_R2.fastq.gz

# Sample name — used for output file naming
SAMPLE=SRR062634

# Directory containing the reference genome FASTA
GENOME_DIR=/path/to/your/ref/directory

# Reference genome filename inside GENOME_DIR
GENOME_FILE=chr22.fa

# Output directory on your host machine
RESULTS_DIR=./results
